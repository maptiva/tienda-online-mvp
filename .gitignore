# --- PROYECTO CLICANDO: CONFIGURACIÓN DE REPOSITORIO PROFESIONAL ---

# 1. Documentación Externa (Pública)
*.md
!README.md

# 2. Documentación Interna y Auditoría (PRIVADO)
# Estos archivos contienen estrategias, planes y auditorías sensibles
docs/internal/
docs/audit/
plans/
SESION_BACKUP_*.md
Algosaliomal.txt
CODE_REVIEW.txt
*.log

# 3. Base de Datos y Herramientas SQL (PRIVADO)
# Solo permitimos las migraciones estructurales de Supabase
scripts/sql_tools/
sql/
!supabase/migrations/*.sql

# 4. Archivos de Testing y Stress Test (PRIVADO)
tests/security-stress-test.js
tests/test-stats-insert.js

# 5. Secretos y Entorno (CRÍTICO)
.env
.env*.local
.env.development
.env.production
.env.example
.env.local.example
.env.template

# 6. Backups (NUNCA SUBIR)
backups/
!.gitkeep

# 7. Dependencias y Compilación
/node_modules
/dist
.vite/
npm-debug.log*

# 8. IDEs y Sistema
.vscode
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# 8b. Herramientas de IA y Editores (PRIVADO)
.claude/
.opencode/

# 8c. Python cache (nunca subir)
*.pyc
*.pyo
__pycache__/
*.pyd

# 9. Skills de IA (PERMITIDOS)
# Esto es el "cerebro" para que los agentes trabajen correctamente
!.agent/skills/

# 10. Archivos de Datos y Temporales (NUNCA SUBIR)
# CSVs de trabajo, exports e importaciones de datos
*.csv
# Archivos temporales de herramientas externas (Supabase CLI)
supabase/.temp/
# Archivos de resumen y debug de sesiones
resumen_*.txt
debug-*.js

# 11. Scripts Operacionales One-Shot (PRIVADOS, no son del producto)
# Scripts de inyección de tiendas específicas, análisis puntuales y debugging
scripts/one-off/
scratch/
